def ffn_swiglu(x, W1, b1, W2, b2, W3, b3) -> (out) {
    tensor.matmul(x, W1)  -> g1
    tensor.add(g1, b1)    -> gate
    tensor.silu(gate)     -> gate_silu
    tensor.matmul(x, W2)  -> g2
    tensor.add(g2, b2)    -> gate_linear
    tensor.mul(gate_silu, gate_linear) -> gated
    tensor.matmul(gated, W3) -> o1
    tensor.add(o1, b3)    -> out
}
